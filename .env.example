# Pesapal API 3.0 credentials — set these as Environment Variables in Vercel.
# DO NOT commit real values. This file is only a template.

PESAPAL_CONSUMER_KEY=your_consumer_key_here
PESAPAL_CONSUMER_SECRET=your_consumer_secret_here

# Live (default). For testing use: https://cybqa.pesapal.com/pesapalv3
PESAPAL_BASE_URL=https://pay.pesapal.com/v3

# Optional: after the first payment (or after calling /api/pesapal/setup),
# copy the returned ipn_id here so the IPN isn't re-registered each cold start.
# PESAPAL_IPN_ID=
