# Custom error page
ErrorDocument 404 /404.html

# Correct MIME type for the web manifest
AddType application/manifest+json .webmanifest

# Never serve secret/config files as plain text
<FilesMatch "(^\.env|config\.php|\.json)$">
  Require all denied
</FilesMatch>

# HTML, JS and CSS: always revalidate so deploys take effect immediately.
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|html)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>

# Images can cache (they rarely change)
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg "access plus 30 days"
  ExpiresByType image/png "access plus 30 days"
  ExpiresByType image/svg+xml "access plus 30 days"
</IfModule>
